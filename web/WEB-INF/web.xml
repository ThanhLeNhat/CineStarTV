<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5"
         xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
         http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">

    <display-name>CineStarTV</display-name>

    <!-- ============================================================
         FILTERS — khai báo trước servlet
         ============================================================ -->

    <!-- UTF-8 encoding cho TẤT CẢ request/response -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>ignore</param-name>
            <param-value>false</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- AuthenticationFilter: yêu cầu đăng nhập -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>controller.AuthenticationFilter</filter-class>
    </filter>

    <!-- AuthorizationFilter: chỉ ADMIN -->
    <filter>
        <filter-name>AdminOnlyFilter</filter-name>
        <filter-class>controller.AuthorizationFilter</filter-class>
        <init-param>
            <param-name>allowedRoles</param-name>
            <param-value>ADMIN</param-value>
        </init-param>
    </filter>

    <!-- AuthorizationFilter: ADMIN hoặc STAFF -->
    <filter>
        <filter-name>StaffFilter</filter-name>
        <filter-class>controller.AuthorizationFilter</filter-class>
        <init-param>
            <param-name>allowedRoles</param-name>
            <param-value>ADMIN,STAFF</param-value>
        </init-param>
    </filter>

    <!-- ============================================================
         FILTER MAPPINGS
         AuthenticationFilter → các URL cần đăng nhập
         AdminOnlyFilter      → AdminController (chỉ ADMIN)
         StaffFilter          → ShowtimeController, BookingController... (ADMIN + STAFF)
         ============================================================ -->

    <!-- Yêu cầu đăng nhập -->
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/BookingController</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/ProfileController</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/ReviewController</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/NotificationController</url-pattern>
    </filter-mapping>

    <!-- Chỉ ADMIN mới vào được -->
    <filter-mapping>
        <filter-name>AdminOnlyFilter</filter-name>
        <url-pattern>/AdminController</url-pattern>
    </filter-mapping>

    <!-- ADMIN hoặc STAFF -->
    <filter-mapping>
        <filter-name>StaffFilter</filter-name>
        <url-pattern>/ShowtimeController</url-pattern>
    </filter-mapping>

    <!-- ============================================================
         SERVLETS
         ============================================================ -->

    <servlet>
        <servlet-name>MainController</servlet-name>
        <servlet-class>controller.MainController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MainController</servlet-name>
        <url-pattern>/MainController</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HomeController</servlet-name>
        <servlet-class>controller.HomeController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeController</servlet-name>
        <url-pattern>/HomeController</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controller.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/LoginController</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controller.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/LogoutController</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterController</servlet-name>
        <servlet-class>controller.RegisterController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterController</servlet-name>
        <url-pattern>/RegisterController</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MovieController</servlet-name>
        <servlet-class>controller.MovieController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MovieController</servlet-name>
        <url-pattern>/MovieController</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminController</servlet-name>
        <servlet-class>controller.AdminController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminController</servlet-name>
        <url-pattern>/AdminController</url-pattern>
    </servlet-mapping>

    <!-- ============================================================
         WELCOME FILE
         ============================================================ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ============================================================
         JSP CONFIG — ép UTF-8 cho tất cả JSP
         ============================================================ -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <page-encoding>UTF-8</page-encoding>
        </jsp-property-group>
    </jsp-config>

    <!-- ============================================================
         SESSION TIMEOUT
         ============================================================ -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ============================================================
         ERROR PAGES
         ============================================================ -->
    <error-page>
        <error-code>403</error-code>
        <location>/error/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>

</web-app>
